# M5Stack Tab5 configuration template.
# Copy this file to sdkconfig.tab5.defaults, then fill in the local Wi-Fi
# credentials and MQTT broker URI. sdkconfig.tab5.defaults is gitignored.

# Tab5 C6 Wi-Fi coprocessor: SDIO slot 1 and power gate.
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CLK_SLOT_1=12
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CMD_SLOT_1=13
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D0_SLOT_1=11
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D1_4BIT_BUS_SLOT_1=10
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D2_4BIT_BUS_SLOT_1=9
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D3_4BIT_BUS_SLOT_1=8
CONFIG_ESP_HOSTED_SDIO_GPIO_RESET_SLAVE=15
CONFIG_ESP_HOSTED_SDIO_RESET_ACTIVE_HIGH=y
# CONFIG_ESP_HOSTED_SDIO_RESET_ACTIVE_LOW is not set
CONFIG_MQJS_TAB5_POWER=y

# Local network settings. Replace these values after copying the file.
CONFIG_MQJS_WIFI_SSID="YOUR_WIFI_SSID"
CONFIG_MQJS_WIFI_PASSWORD="YOUR_WIFI_PASSWORD"
CONFIG_MQJS_TASK_BROKER="mqtt://192.168.1.2"

# Tab5 display, touch, SSH client, and camera.
CONFIG_MQJS_TAB5_UI=y
CONFIG_MQJS_SSH=y
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_MQJS_CAMERA=y

# Camera pipeline (SC2356 over MIPI-CSI).
CONFIG_ESP_VIDEO_ENABLE_MIPI_CSI_VIDEO_DEVICE=y
CONFIG_ESP_VIDEO_ENABLE_ISP=y
CONFIG_ESP_VIDEO_ENABLE_ISP_VIDEO_DEVICE=y
CONFIG_ESP_VIDEO_ENABLE_ISP_PIPELINE_CONTROLLER=y
CONFIG_CAMERA_SC202CS=y
CONFIG_CAMERA_SC202CS_AUTO_DETECT=y
CONFIG_CAMERA_SC202CS_AUTO_DETECT_MIPI_INTERFACE_SENSOR=y
CONFIG_CAMERA_SC202CS_MIPI_RAW8_1280x720_30FPS=y
CONFIG_CAMERA_SC202CS_MIPI_RAW8_1600X1200_30FPS=y
CONFIG_CAMERA_SC202CS_MIPI_DEFAULT_FMT_RAW8_1600X1200_30FPS=y
CONFIG_ESP_IPA_AGC_ALGORITHM=y
CONFIG_ESP_IPA_AGC_THRESHOLD=y
CONFIG_ESP_IPA_AWB_ALGORITHM=y
CONFIG_ESP_IPA_AWB_GRAY_WORLD=y
CONFIG_ESP_IPA_GAMMA_ALGORITHM=y
CONFIG_ESP_IPA_GAMMA_LUMA=y
CONFIG_ESP_IPA_DENOISING_ALGORITHM=y
CONFIG_ESP_IPA_DENOISING_GAIN_FEEDBACK=y
CONFIG_ESP_IPA_SHARPEN_ALGORITHM=y
CONFIG_ESP_IPA_SHARPEN_FREQUENCY_FEEDBACK=y

# HTTPS support for http.get().
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y

# Speaker playback path (ES8388 + I2S; audio_tab5 component).
CONFIG_MQJS_TAB5_AUDIO=y
